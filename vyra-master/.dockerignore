# ============================================
# VYRA - Docker Ignore
# ============================================

# Version Control
.git/
.gitignore

# Virtual Environment
.venv/
venv/
ENV/

# PostgreSQL (standalone kurulum)
pgsql/

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Temp & Logs
Gecici_Dosyalar_Sil/
*.log
logs/
*.tmp
*.bak

# ML Training Cache
catboost_info/

# Environment (container içinde .env.example kullanılır)
.env
.env.local
.env.production

# Documentation (runtime'da gerekli değil)
docs/
*.md
!requirements.txt

# Tests (production image'da gerekli değil)
tests/

# OS
.DS_Store
Thumbs.db

# Gemini/Agent
.gemini/
.agent/
