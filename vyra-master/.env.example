# ============================================
# VYRA L1 Support API - Environment Template
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   copy .env.example .env
# ============================================
# Versiyon: 2.52.1
# ============================================

# -------------------------------------------------
#  Genel Ayarlar
# -------------------------------------------------
debug=False

# -------------------------------------------------
#  Tarayıcı / Playwright Ayarları
# -------------------------------------------------
# Playwright'ın tarayıcı profilini yazabilmesi için gerekli ev dizini.
HOME=C:\Users\YOUR_USERNAME

# -------------------------------------------------
#  JWT Güvenlik (ZORUNLU - en az 32 karakter)
# -------------------------------------------------
# Üretmek için: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_python_-c_import_secrets_print_secrets.token_urlsafe_48
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------------
#  PostgreSQL Veritabanı
# -------------------------------------------------
DB_HOST=localhost
DB_PORT=5005
DB_NAME=vyra
DB_USER=vyra_app
DB_PASSWORD=CHANGE_ME_SET_YOUR_DB_PASSWORD

# PostgreSQL bin dizini (sistem kurulumu için)
# Portable kurulumda (pgsql/ klasörü) boş bırakılabilir.
# Örnek: C:\Program Files\PostgreSQL\16\bin
PG_BIN_DIR=

# -------------------------------------------------
#  RAG / Embedding Ayarları
# -------------------------------------------------
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=100
MAX_FILE_SIZE_MB=50

# -------------------------------------------------
#  Cache & Performans
# -------------------------------------------------
EMBEDDING_CACHE_SIZE=500
FUZZY_CACHE_SIZE=500
LLM_BYPASS_THRESHOLD=0.70

# -------------------------------------------------
#  RAG Arama Parametreleri
# -------------------------------------------------
RAG_DEFAULT_RESULTS=5
RAG_MIN_SCORE=0.4

# -------------------------------------------------
#  Scheduler
# -------------------------------------------------
SCHEDULER_INTERVAL_SECONDS=300

# -------------------------------------------------
#  CORS (Production için)
# -------------------------------------------------
# Virgülle ayrılmış production frontend URL'leri
# Örnek: CORS_ORIGINS=https://vyra.company.com,https://admin.vyra.company.com
# Boş bırakılırsa sadece localhost development origins kullanılır
CORS_ORIGINS=
